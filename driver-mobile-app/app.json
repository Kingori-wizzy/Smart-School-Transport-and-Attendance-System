{
  "expo": {
    "name": "Driver App",
    "slug": "driver-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#667eea"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartschool.driver",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to location to track bus routes",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to location for background tracking",
        "NSCameraUsageDescription": "Allow Driver App to access camera to scan student QR codes.",
        "NSFaceIDUsageDescription": "This app uses Face ID for secure login",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#667eea"
      },
      "package": "com.smartschool.driver",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "plugins": [
      "expo-local-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Driver App to use your location for bus tracking.",
          "locationAlwaysPermission": "Allow Driver App to track bus location in the background."
        }
      ],
      [
        "expo-barcode-scanner",
        {
          "cameraPermission": "Allow Driver App to access camera to scan student QR codes."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 23,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "kotlinVersion": "1.8.10",
            "extraGradleArguments": {
              "android.suppressUnsupportedCompileSdk": "34"
            }
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2c7b18d0-06ee-4a7d-b215-3cf26bef8ca9"
      }
    },
    "owner": "wizzysley"
  }
}