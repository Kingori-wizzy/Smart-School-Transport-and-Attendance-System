# Node modules - ignore in all directories
node_modules/
**/node_modules/
*/node_modules/
*/*/node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Environment variables
.env
.env.local
.env.*.local
.env.example

# Build output
dist/
build/
*/dist/
*/build/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE settings
.vscode/
.idea/
*.swp
*.swo
*~

# Expo/React Native
.expo/
.expo-shared/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.cert

# Package manager lock files (keep these for consistency)
# package-lock.json - you might want to keep this
# yarn.lock - you might want to keep this

# Test coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp