{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "ubuntu-22.04-jdk-17-ndk-r21e"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "image": "ubuntu-22.04-jdk-17-ndk-r21e"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://your-api-url.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "image": "ubuntu-22.04-jdk-17-ndk-r21e"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.100.3:5000/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}