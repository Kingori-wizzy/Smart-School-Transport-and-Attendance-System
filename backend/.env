# ============================================
# CACHE CONFIGURATION (Redis)
# ============================================
# Redis connection (Docker container)
REDIS_URL=redis://localhost:6379

# Redis with password (if configured)
# REDIS_URL=redis://:password@localhost:6379

# For Heroku/Cloud Redis with TLS:
# REDIS_TLS_URL=rediss://:password@host:port
# REDIS_TLS=true

# Cache settings
CACHE_ENABLED=true
CACHE_PREFIX=smart_school:
CACHE_DEFAULT_TTL=300
CACHE_MAX_ITEMS=1000

# ============================================
# AI MODELS CONFIGURATION
# ============================================
# Absenteeism Prediction Model
AI_ABSENTEEISM_ENABLED=true
ABSENTEEISM_TRAINING_EPOCHS=50
ABSENTEEISM_PREDICTION_DAYS=30

# Route Optimization Model
AI_ROUTE_OPTIMIZATION_ENABLED=true
ROUTE_OPTIMIZATION_EPOCHS=100

# ============================================
# NOTIFICATION CONFIGURATION
# ============================================
# Push Notifications (Firebase Cloud Messaging)
FCM_ENABLED=false
# FCM_SERVER_KEY=your_fcm_server_key

# Email Notifications
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_BOARDING_ALERTS=true
EMAIL_ALIGHTING_ALERTS=true
EMAIL_DELAY_ALERTS=true
EMAIL_EMERGENCY_ALERTS=true

# SMS Notifications
SMS_NOTIFICATIONS_ENABLED=true
SMS_BOARDING_ALERTS=true
SMS_ALIGHTING_ALERTS=true
SMS_DELAY_ALERTS=true
SMS_EMERGENCY_ALERTS=true

# ============================================
# SYSTEM CONFIGURATION
# ============================================
# Environment
NODE_ENV=development
# NODE_ENV=production

# Logging
LOG_LEVEL=info
# LOG_LEVEL=debug

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# ============================================
# DOCKER CONTAINER NAMES (For reference)
# ============================================
# MongoDB: my-mongo (running on port 27017)
# Redis: my-redis (running on port 6379)